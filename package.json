{
  "name": "chia-keo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "test:watch": "vitest",
    "pages:dev": "npm run cloudflare:preview",
    "deploy": "npm run cloudflare:deploy",
    "cloudflare:preview": "npm run build && wrangler pages dev dist --port 8788",
    "cloudflare:deploy": "npm run build && wrangler pages deploy dist --project-name chiakeo"
  },
  "dependencies": {
    "@dicebear/core": "^10.3.0",
    "@dicebear/styles": "^10.2.0",
    "@headlessui/react": "^2.2.10",
    "@radix-ui/react-select": "^2.3.2",
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.18.1",
    "sonner": "^2.0.7",
    "tailwindcss": "^4.0.0",
    "vite": "^7.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.7.0",
    "vitest": "^4.1.9",
    "wrangler": "^4.106.0"
  }
}
